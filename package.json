{
	"name": "vscode-dxl",
	"displayName": "vscode-dxl",
	"description": "DXL support for VS Code",
	"version": "0.7.2",
	"publisher": "enochpang",
	"repository": "https://github.com/enochpang/vscode-dxl",
	"author": "Enoch Pang",
	"license": "MPL-2.0",
	"engines": {
		"vscode": "^1.77.0"
	},
	"categories": [
		"Programming Languages",
		"Other"
	],
	"activationEvents": [],
	"main": "./dist/extension.js",
	"contributes": {
		"languages": [
			{
				"id": "dxl",
				"aliases": [
					"DXL",
					"dxl"
				],
				"extensions": [
					".dxl",
					".inc"
				],
				"configuration": "./language-configuration.json"
			}
		],
		"commands": [
			{
				"command": "vscode-dxl.showCst",
				"title": "Show CST"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "npm run build",
		"build": "tsc",
		"watch": "tsc -watch",
		"test": "vitest",
		"format": "biome format --write src/"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.2",
		"@types/node": "^24.3.0",
		"@types/vscode": "^1.99.1",
		"ts-node": "^10.9.2",
		"typescript": "^5.9.2",
		"vitest": "^3.2.4"
	}
}